# Default configuration for coding-optimized setup
# Copy to .env and modify as needed

# Model configuration
MODEL=/models/Qwen_Qwen3.5-35B-A3B-Q4_K_M.gguf
MODELS_PATH=C:/Users/Tobias/.cache/llama.cpp/models

# Server configuration  
PORT=8080

# Performance tuning for RTX 4080 Laptop (12GB VRAM)
# Context size: 49152 (48K) is optimal for coding tasks
# - 32K: Fast but limited for large codebases
# - 48K: Best balance of speed and context (recommended)
# - 64K: Works but ~10% slower
# - 96K: Too slow, not recommended
CTX_SIZE=49152

# GPU layers: 15 for this model on 12GB VRAM
# Increasing may cause OOM
N_GPU_LAYERS=15

# Batch size for prompt processing
BATCH_SIZE=512

# KV cache quantization
# q8_0: Good balance (recommended)
# f16: Higher quality, more memory
# q4_0: Less memory, slightly lower quality
CACHE_TYPE=q8_0
